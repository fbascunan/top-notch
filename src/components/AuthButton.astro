---
import { t, type Locale } from "../i18n/index";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;

const user = Astro.locals.user;
const supabaseUrl = import.meta.env.SUPABASE_URL ?? "";
const origin = Astro.url.origin;
const signInUrl = `${supabaseUrl}/auth/v1/authorize?provider=google&redirect_to=${origin}/api/auth/callback`;
---

{user ? (
  <div class="flex items-center gap-2">
    {user.avatarUrl && (
      <img
        src={user.avatarUrl}
        alt=""
        class="w-8 h-8 rounded-full"
        width="32"
        height="32"
      />
    )}
    <form method="POST" action="/api/auth/logout">
      <button
        type="submit"
        class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
      >
        {t(lang, "auth.signOut")}
      </button>
    </form>
  </div>
) : (
  <a
    href={signInUrl}
    class="px-3 py-1.5 rounded-md text-sm font-medium border border-neutral-200 text-neutral-600 hover:text-primary-600 hover:border-primary-300 transition-colors duration-[var(--transition-fast)]"
  >
    {t(lang, "auth.signIn")}
  </a>
)}
