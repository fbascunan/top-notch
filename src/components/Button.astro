---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "outline";
  size?: "sm" | "md" | "lg";
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = "primary", size = "md", href, class: className = "", ...rest } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center font-heading font-semibold rounded-lg transition-all duration-[var(--transition-base)] focus:outline-2 focus:outline-offset-2 focus:outline-primary-500 cursor-pointer";

const variantClasses: Record<string, string> = {
  primary: "bg-primary-600 text-white hover:bg-primary-700 active:bg-primary-800 shadow-sm hover:shadow-md",
  secondary: "bg-secondary-100 text-secondary-900 hover:bg-secondary-200 active:bg-secondary-300",
  ghost: "text-secondary-700 hover:bg-secondary-100 active:bg-secondary-200",
  outline: "border-2 border-primary-600 text-primary-600 hover:bg-primary-50 active:bg-primary-100",
};

const sizeClasses: Record<string, string> = {
  sm: "text-sm px-3 py-1.5 gap-1.5",
  md: "text-base px-5 py-2.5 gap-2",
  lg: "text-lg px-7 py-3.5 gap-2.5",
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].join(" ");
---

{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={classes} {...rest}>
      <slot />
    </button>
  )
}
