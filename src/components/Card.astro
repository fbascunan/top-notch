---
interface Props {
  title: string;
  description?: string;
  href?: string;
  class?: string;
}

const { title, description, href, class: className = "" } = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "block bg-white rounded-xl border border-neutral-200 overflow-hidden shadow-sm transition-all duration-[var(--transition-base)]",
    href && "hover:shadow-lg hover:-translate-y-1",
    className,
  ]}
>
  <slot name="image" />
  <div class="p-5 sm:p-6">
    <h3 class="font-heading text-lg font-bold text-neutral-900">{title}</h3>
    {description && <p class="mt-2 text-neutral-600 text-sm leading-relaxed">{description}</p>}
    <slot />
  </div>
</Tag>
