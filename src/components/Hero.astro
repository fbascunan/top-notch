---
import Container from "./Container.astro";
import Button from "./Button.astro";
import { t, getLocalePrefix, type Locale } from "../i18n/index";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const prefix = getLocalePrefix(lang);
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-primary-100/40 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] rounded-full bg-accent-100/30 blur-3xl"></div>
  </div>

  <Container class="relative py-24 sm:py-32 lg:py-40">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-heading text-sm sm:text-base font-semibold uppercase tracking-widest text-primary-600 mb-4">
        {t(lang, "hero.eyebrow")}
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-neutral-900 leading-tight">
        {t(lang, "hero.heading")}<span class="text-primary-600">{t(lang, "hero.headingHighlight")}</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-neutral-600 max-w-2xl mx-auto leading-relaxed">
        {t(lang, "hero.description")}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href={`${prefix}/contact`} variant="primary" size="lg">{t(lang, "hero.ctaPrimary")}</Button>
        <Button href={`${prefix}/portfolio`} variant="outline" size="lg">{t(lang, "hero.ctaSecondary")}</Button>
      </div>
    </div>
  </Container>
</section>
