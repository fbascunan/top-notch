---
import { t, type Locale } from "../i18n/index";
import type { HumanAction } from "../lib/human-actions-data";
import { groupByMilestone } from "../lib/human-actions-data";

interface Props {
  actions: HumanAction[];
  lang?: Locale;
  isMember?: boolean;
  showProject?: boolean;
}

const { actions, lang = "es", isMember = false, showProject = false } = Astro.props;
const grouped = groupByMilestone(actions);
const pendingCount = actions.filter((a) => a.status === "pending").length;
const blockerCount = actions.filter((a) => a.is_blocker && a.status === "pending").length;
---

{actions.length === 0 ? (
  <p class="text-center text-neutral-500 text-sm py-8">{t(lang, "humanActions.noActions")}</p>
) : (
  <div>
    {/* Summary badges */}
    <div class="flex gap-3 mb-6 text-sm">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-700 font-medium">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {pendingCount} {t(lang, "humanActions.pendingCount")}
      </span>
      {blockerCount > 0 && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-red-50 text-red-700 font-medium">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          {blockerCount} {t(lang, "humanActions.blockerCount")}
        </span>
      )}
    </div>

    {/* Grouped by milestone */}
    {[...grouped.entries()].map(([milestone, milestoneActions]) => (
      <div class="mb-8 last:mb-0">
        <h4 class="text-sm font-semibold text-neutral-500 uppercase tracking-wider mb-3">
          {milestone}
        </h4>
        <div class="space-y-2">
          {milestoneActions.map((action) => (
            <div
              class:list={[
                "flex items-start gap-3 p-3 rounded-lg border transition-colors",
                action.status === "done"
                  ? "bg-neutral-50 border-neutral-200 opacity-60"
                  : action.is_blocker
                    ? "bg-red-50/50 border-red-200"
                    : "bg-white border-neutral-200",
              ]}
              data-action-row={action.id}
            >
              {/* Checkbox / status */}
              {isMember ? (
                <button
                  type="button"
                  data-toggle-action={action.id}
                  data-current-status={action.status}
                  class="mt-0.5 shrink-0 cursor-pointer"
                  title={action.status === "done" ? t(lang, "humanActions.markPending") : t(lang, "humanActions.markDone")}
                >
                  {action.status === "done" ? (
                    <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-neutral-300 hover:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="9" />
                    </svg>
                  )}
                </button>
              ) : (
                <span class="mt-0.5 shrink-0">
                  {action.status === "done" ? (
                    <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="9" />
                    </svg>
                  )}
                </span>
              )}

              {/* Description + badges */}
              <div class="flex-1 min-w-0">
                <p class:list={[
                  "text-sm",
                  action.status === "done" ? "text-neutral-500 line-through" : "text-neutral-800",
                ]}>
                  {action.description}
                </p>
                <div class="flex flex-wrap items-center gap-2 mt-1.5">
                  {action.is_blocker && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-700">
                      {t(lang, "humanActions.blocker")}
                    </span>
                  )}
                  {!action.is_blocker && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-600">
                      {t(lang, "humanActions.postDeploy")}
                    </span>
                  )}
                  {showProject && action.project_name && (
                    <span class="text-xs text-neutral-400">{action.project_name}</span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
)}
