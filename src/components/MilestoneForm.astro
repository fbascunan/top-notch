---
import { t, type Locale } from "../i18n/index";

interface Props {
  lang?: Locale;
  projectId: number;
  milestone?: {
    id: number;
    number: number;
    title: string;
    description: string | null;
    status: string;
    blocking: string | null;
  };
}

const { lang = "es", projectId, milestone } = Astro.props;
const mode = milestone ? "edit" : "create";
---

<div data-milestone-form>
  <form
    data-form={mode}
    data-milestone-id={milestone?.id ?? ""}
    data-project-id={projectId}
    class="rounded-lg border-2 border-dashed border-neutral-300 bg-white p-6 space-y-4"
  >
    {/* Title */}
    <div>
      <label for="milestone-title" class="block text-sm font-medium text-neutral-700 mb-1">
        {t(lang, "forms.milestoneTitle")} *
      </label>
      <input
        type="text"
        id="milestone-title"
        name="title"
        required
        value={milestone?.title ?? ""}
        class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 outline-none"
      />
    </div>

    {/* Description */}
    <div>
      <label for="milestone-description" class="block text-sm font-medium text-neutral-700 mb-1">
        {t(lang, "forms.milestoneDescription")}
      </label>
      <textarea
        id="milestone-description"
        name="description"
        rows="3"
        class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 outline-none resize-y"
      >{milestone?.description ?? ""}</textarea>
    </div>

    {/* Status */}
    <div>
      <label for="milestone-status" class="block text-sm font-medium text-neutral-700 mb-1">
        {t(lang, "forms.milestoneStatus")}
      </label>
      <select
        id="milestone-status"
        name="status"
        class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 outline-none bg-white"
      >
        <option value="Planned" selected={milestone?.status === "Planned"}>Planned</option>
        <option value="In Progress" selected={milestone?.status === "In Progress"}>In Progress</option>
        <option value="Done" selected={milestone?.status === "Done"}>Done</option>
        <option value="Blocked" selected={milestone?.status === "Blocked"}>Blocked</option>
      </select>
    </div>

    {/* Blocking */}
    <div>
      <label for="milestone-blocking" class="block text-sm font-medium text-neutral-700 mb-1">
        {t(lang, "forms.milestoneBlocking")}
      </label>
      <input
        type="text"
        id="milestone-blocking"
        name="blocking"
        value={milestone?.blocking ?? ""}
        placeholder="M1, M2"
        class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 outline-none"
      />
    </div>

    {/* Actions */}
    <div class="flex items-center gap-3 pt-2">
      <button
        type="submit"
        class="inline-flex items-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 transition-colors"
      >
        {t(lang, "forms.save")}
      </button>
      <button
        type="button"
        data-cancel
        class="inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50 transition-colors"
      >
        {t(lang, "forms.cancel")}
      </button>
    </div>
  </form>
</div>
