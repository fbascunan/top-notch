---
import Container from "./Container.astro";
import AuthButton from "./AuthButton.astro";
import AuthButtonFallback from "./AuthButtonFallback.astro";
import { t, getLocalizedPath, getLocalePrefix, type Locale } from "../i18n/index";

interface Props {
  class?: string;
  lang?: Locale;
  isMember?: boolean;
}

const { class: className = "", lang = "es", isMember = false } = Astro.props;

const prefix = getLocalePrefix(lang);

const navLinks = [
  { label: t(lang, "nav.services"), href: `${prefix}/services` },
  { label: t(lang, "projects.nav"), href: `${prefix}/projects` },
  ...(isMember ? [
    { label: t(lang, "runs.nav"), href: `${prefix}/runs` },
    { label: t(lang, "humanActions.nav"), href: `${prefix}/human-actions` },
  ] : []),
  { label: t(lang, "docs.nav"), href: `${prefix}/docs` },
  { label: t(lang, "nav.blog"), href: `${prefix}/blog` },
  { label: t(lang, "nav.contact"), href: `${prefix}/contact` },
];

const currentPath = Astro.url.pathname;
const alternateLang: Locale = lang === "es" ? "en" : "es";
const switchPath = getLocalizedPath(currentPath, alternateLang);
---

<header class:list={["sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-neutral-200", className]}>
  <Container>
    <nav class="flex items-center justify-between h-16 sm:h-18">
      <!-- Logo -->
      <a href={`${prefix}/` || "/"} class="flex items-center gap-2 font-heading text-xl font-bold text-primary-600">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="28" height="28" rx="6" fill="currentColor" />
          <path d="M8 18V10h2.5l3.5 5 3.5-5H20v8h-2.5v-4.5L14 17l-3.5-4.5V18H8z" fill="white" />
        </svg>
        TopNotch
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "px-3 py-2 rounded-md text-sm font-medium transition-colors duration-[var(--transition-fast)]",
                currentPath.startsWith(link.href)
                  ? "text-primary-600 bg-primary-50"
                  : "text-neutral-600 hover:text-neutral-900 hover:bg-neutral-50",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
        {/* Language switcher */}
        <li class="ml-2">
          <a
            href={switchPath}
            class="px-2.5 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider border border-neutral-200 text-neutral-600 hover:text-primary-600 hover:border-primary-300 transition-colors duration-[var(--transition-fast)]"
            aria-label={lang === "es" ? "Switch to English" : "Cambiar a Español"}
          >
            {alternateLang.toUpperCase()}
          </a>
        </li>
        <li class="ml-2">
          <AuthButton server:defer lang={lang}>
            <AuthButtonFallback slot="fallback" lang={lang} />
          </AuthButton>
        </li>
      </ul>

      <!-- Mobile hamburger -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-neutral-600 hover:bg-neutral-100"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </Container>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-200 bg-white">
    <Container>
      <ul class="py-3 space-y-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block px-3 py-2 rounded-md text-base font-medium transition-colors",
                currentPath.startsWith(link.href)
                  ? "text-primary-600 bg-primary-50"
                  : "text-neutral-600 hover:text-neutral-900 hover:bg-neutral-50",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2 border-t border-neutral-100 mt-2">
          <a
            href={switchPath}
            class="block px-3 py-2 rounded-md text-base font-medium text-neutral-600 hover:text-primary-600 hover:bg-neutral-50 transition-colors"
          >
            {lang === "es" ? "🇬🇧 English" : "🇨🇱 Español"}
          </a>
        </li>
        <li class="pt-2 border-t border-neutral-100 mt-2">
          <AuthButton server:defer lang={lang}>
            <AuthButtonFallback slot="fallback" lang={lang} />
          </AuthButton>
        </li>
      </ul>
    </Container>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("menu-icon-open")!;
  const iconClose = document.getElementById("menu-icon-close")!;

  btn.addEventListener("click", () => {
    const isOpen = menu.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
    iconOpen.classList.toggle("hidden");
    iconClose.classList.toggle("hidden");
  });
</script>
