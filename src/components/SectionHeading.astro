---
interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  align?: "left" | "center";
  as?: "h1" | "h2";
  class?: string;
}

const { eyebrow, heading, subheading, align = "center", as: Tag = "h2", class: className = "" } = Astro.props;
---

<div class:list={[align === "center" && "text-center", className]}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-2">{eyebrow}</p>
  )}
  <Tag class="font-heading text-3xl sm:text-4xl font-bold text-neutral-900">{heading}</Tag>
  {subheading && (
    <p class="mt-3 text-lg text-neutral-600 max-w-2xl" class:list={[align === "center" && "mx-auto"]}>
      {subheading}
    </p>
  )}
</div>
