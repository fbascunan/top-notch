---
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";
import { t, tArray, getLocalePrefix, type Locale } from "../i18n/index";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const prefix = getLocalePrefix(lang);

const serviceItems = tArray<{ title: string; description: string }>(lang, "services.items");

const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>`,
];

const slugs = ["web-platforms", "mobile-apps", "ai-products", "data-driven-apps"];

const services = serviceItems.map((item, i) => ({
  ...item,
  href: `${prefix}/services#${slugs[i]}`,
  icon: icons[i],
}));
---

<section class="py-20 sm:py-28 bg-white">
  <Container>
    <SectionHeading
      eyebrow={t(lang, "services.eyebrow")}
      heading={t(lang, "services.heading")}
      subheading={t(lang, "services.subheading")}
      align="center"
    />

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {services.map((service) => (
        <a
          href={service.href}
          class="group block rounded-xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-base hover:shadow-lg hover:-translate-y-1 hover:border-primary-200"
        >
          <div class="mb-4 inline-flex items-center justify-center w-12 h-12 rounded-lg bg-primary-50 text-primary-600 transition-colors group-hover:bg-primary-100">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="font-heading text-lg font-semibold text-neutral-900 mb-2">{service.title}</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">{service.description}</p>
        </a>
      ))}
    </div>
  </Container>
</section>
