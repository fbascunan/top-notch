---
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";

const differentiators = [
  {
    title: "Ship fast",
    description: "We move quickly without cutting corners. Lean sprints, rapid prototyping, and continuous delivery mean your product gets to market sooner.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    title: "Craft quality",
    description: "Clean code, thorough testing, and thoughtful architecture. We build software that scales, performs, and stands the test of time.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>`,
  },
  {
    title: "Communicate clearly",
    description: "No jargon, no black boxes. You get full visibility into progress, decisions, and trade-offs at every step of the project.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
  },
];
---

<section class="py-20 sm:py-28 bg-neutral-50">
  <Container>
    <SectionHeading
      eyebrow="Why us"
      heading="What sets TopNotch apart"
      subheading="We combine speed, quality, and transparency to deliver projects that exceed expectations."
      align="center"
    />

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {differentiators.map((item) => (
        <div class="text-center">
          <div class="mx-auto mb-5 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary-100 text-primary-600">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-heading text-xl font-semibold text-neutral-900 mb-3">{item.title}</h3>
          <p class="text-neutral-600 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
