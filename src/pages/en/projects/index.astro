---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Container from "@/components/Container.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import { t } from "../../../i18n/index";
import { getAllProjects } from "../../../lib/projects-data";

const lang = "en";
const projects = await getAllProjects();
---

<BaseLayout
  title={t(lang, "meta.projectsTitle")}
  description={t(lang, "meta.projectsDescription")}
  url="/en/projects"
  breadcrumbs={[{ name: "Home", url: "/en" }, { name: t(lang, "projects.nav"), url: "/en/projects" }]}
  lang={lang}
>
  <Navbar lang={lang} />

  <main>
    <section class="pt-24 pb-20 sm:pt-32 sm:pb-28 bg-neutral-50">
      <Container>
        <SectionHeading
          eyebrow={t(lang, "projects.eyebrow")}
          heading={t(lang, "projects.heading")}
          subheading={t(lang, "projects.subheading")}
          align="center"
          as="h1"
        />

        {projects.length === 0 ? (
          <p class="text-center text-neutral-500 mt-12">{t(lang, "projects.noProjects")}</p>
        ) : (
          <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {projects.map((project) => (
              <ProjectCard
                name={project.name}
                slug={project.slug}
                status={project.status}
                domain={project.domain}
                notes={project.notes}
                progressPercent={project.progressPercent}
                doneMilestones={project.doneMilestones}
                totalMilestones={project.totalMilestones}
                href={`/en/projects/${project.slug}`}
                lang={lang}
              />
            ))}
          </div>
        )}
      </Container>
    </section>

    <CtaBanner lang={lang} />
  </main>

  <Footer lang={lang} />
</BaseLayout>
