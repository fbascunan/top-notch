---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Container from "@/components/Container.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Badge from "@/components/Badge.astro";
import MilestoneTimeline from "@/components/MilestoneTimeline.astro";
import MilestoneForm from "@/components/MilestoneForm.astro";
import DocumentCard from "@/components/DocumentCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import RunHistoryTable from "@/components/RunHistoryTable.astro";
import { t } from "../../i18n/index";
import { getProjectBySlug } from "../../lib/projects-data";
import { getProjectDocuments } from "../../lib/documents-data";
import { getRunHistoryForProject, hasActiveRun } from "../../lib/run-history-data";

const lang = "es";
const isMember = Astro.locals.isMember;

const { slug } = Astro.params;
const project = await getProjectBySlug(slug!);
const projectDocs = project ? await getProjectDocuments(project.id) : [];
const runHistory = project ? await getRunHistoryForProject(project.id) : [];
const projectHasActiveRun = project ? await hasActiveRun(project.id) : false;
const nextMilestone = project?.milestones.find((m) => m.status === "Planned" || m.status === "In Progress");

if (!project) {
  return Astro.redirect("/404");
}

const statusVariant: Record<string, "success" | "primary" | "warning" | "default"> = {
  Active: "success",
  Planned: "primary",
  "On Hold": "warning",
  Done: "default",
};

const statusLabel: Record<string, string> = {
  Active: t(lang, "projects.statusActive"),
  Planned: t(lang, "projects.statusPlanned"),
  "On Hold": t(lang, "projects.statusOnHold"),
  Done: t(lang, "projects.statusDone"),
};
---

<BaseLayout
  title={`${project.name} — TopNotch`}
  description={project.notes ?? `Proyecto ${project.name} — progreso de milestones y hoja de ruta.`}
  url={`/projects/${slug}`}
  breadcrumbs={[
    { name: "Inicio", url: "/" },
    { name: t(lang, "projects.nav"), url: "/projects" },
    { name: project.name, url: `/projects/${slug}` },
  ]}
  lang={lang}
>
  <Navbar lang={lang} isMember={isMember} />

  <main>
    {/* Header section */}
    <section class="pt-24 pb-12 sm:pt-32 sm:pb-16 bg-neutral-50">
      <Container>
        <a
          href="/projects"
          class="inline-flex items-center text-sm text-neutral-500 hover:text-primary-600 transition-colors mb-6"
        >
          <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          {t(lang, "projects.backToProjects")}
        </a>

        <div class="flex flex-wrap items-start gap-4 mb-6">
          <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900">
            {project.name}
          </h1>
          <Badge variant={statusVariant[project.status] ?? "default"} class="mt-1 sm:mt-2">
            {statusLabel[project.status] ?? project.status}
          </Badge>
        </div>

        {project.notes && (
          <p class="text-lg text-neutral-600 max-w-3xl mb-8">{project.notes}</p>
        )}

        {/* Meta info */}
        <div class="flex flex-wrap gap-6 text-sm text-neutral-500">
          {project.domain && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              <a href={`https://${project.domain}`} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 hover:underline">
                {project.domain}
              </a>
            </div>
          )}
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            <span>{project.doneMilestones} {t(lang, "projects.completedOf")} {project.totalMilestones} {t(lang, "projects.milestones").toLowerCase()}</span>
          </div>
        </div>

        {/* Overall progress bar */}
        <div class="mt-6 max-w-md">
          <div class="flex items-center justify-between text-sm text-neutral-500 mb-2">
            <span>{t(lang, "projects.progress")}</span>
            <span class="font-medium text-neutral-900">{project.progressPercent}%</span>
          </div>
          <div class="w-full h-3 bg-neutral-200 rounded-full overflow-hidden">
            <div
              class="h-full rounded-full bg-primary-500 transition-all duration-500"
              style={`width: ${project.progressPercent}%`}
            />
          </div>
        </div>

        {/* Run Next Milestone button */}
        {isMember && nextMilestone && (
          <div class="mt-6">
            <button
              type="button"
              data-run-milestone
              data-project-id={project.id}
              data-project-folder={project.folder}
              data-milestone-id={nextMilestone.id}
              data-milestone-number={nextMilestone.number}
              data-milestone-title={nextMilestone.title}
              disabled={projectHasActiveRun}
              class:list={[
                "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-colors cursor-pointer",
                projectHasActiveRun
                  ? "bg-neutral-200 text-neutral-500 cursor-not-allowed"
                  : "bg-primary-600 text-white hover:bg-primary-700 shadow-sm",
              ]}
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z" />
              </svg>
              {projectHasActiveRun
                ? t(lang, "runs.runInProgress")
                : `${t(lang, "runs.runNextMilestone")} — M${nextMilestone.number}`}
            </button>
          </div>
        )}
      </Container>
    </section>

    {/* Milestone roadmap */}
    <section class="py-16 sm:py-20">
      <Container>
        <SectionHeading
          eyebrow={t(lang, "projects.roadmap")}
          heading={t(lang, "projects.milestones")}
          subheading={`${project.doneMilestones} ${t(lang, "projects.completedOf")} ${project.totalMilestones} milestones ${t(lang, "projects.milestoneDone").toLowerCase()}`}
        />

        <div class="mt-10 max-w-3xl mx-auto">
          <MilestoneTimeline milestones={project.milestones} lang={lang} isMember={isMember} projectId={project.id} projectFolder={project.folder} hasActiveRun={projectHasActiveRun} />

          {/* Milestone action icons (edit/delete per milestone) */}
          {isMember && (
            <div data-milestone-actions class="mt-4 space-y-2">
              {project.milestones.map((m) => (
                <div class="hidden" data-milestone-action-row={m.id} data-milestone-number={m.number} />
              ))}
            </div>
          )}

          {/* Add Milestone button */}
          {isMember && (
            <button
              type="button"
              data-add-milestone-trigger
              class="mt-8 inline-flex items-center gap-2 rounded-md border-2 border-dashed border-neutral-300 px-4 py-2.5 text-sm font-medium text-neutral-500 hover:border-primary-400 hover:text-primary-600 transition-colors cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              {t(lang, "forms.addMilestone")}
            </button>
          )}

          {/* Hidden milestone form */}
          {isMember && (
            <div data-milestone-form-container class="hidden mt-6">
              <MilestoneForm lang={lang} projectId={project.id} />
            </div>
          )}
        </div>
      </Container>
    </section>

    {/* Run history section (member-only) */}
    {isMember && (
      <section class="py-16 sm:py-20 bg-white">
        <Container>
          <SectionHeading
            eyebrow={t(lang, "runs.eyebrow")}
            heading={t(lang, "runs.heading")}
          />
          <div class="mt-10 max-w-4xl mx-auto">
            <RunHistoryTable runs={runHistory} lang={lang} />
          </div>
        </Container>
      </section>
    )}

    {/* Documents section */}
    <section class="py-16 sm:py-20 bg-neutral-50">
      <Container>
        <SectionHeading
          eyebrow={t(lang, "docs.eyebrow")}
          heading={t(lang, "docs.heading")}
        />
        <div class="mt-10 max-w-3xl mx-auto space-y-3">
          {projectDocs.map((doc) => (
            <DocumentCard doc={doc} href={`/docs/${doc.slug}`} lang={lang} editable={isMember} />
          ))}
          {projectDocs.length === 0 && (
            <p class="text-center text-neutral-500 text-sm">{t(lang, "docs.noDocuments")}</p>
          )}
          {isMember && (
            <button
              data-add-project-doc
              data-project-id={project.id}
              class="w-full p-4 rounded-lg border-2 border-dashed border-neutral-300 text-neutral-500 hover:border-primary-400 hover:text-primary-600 transition-colors text-sm cursor-pointer"
            >
              + {t(lang, "docs.addDocument")}
            </button>
          )}
        </div>
      </Container>
    </section>

    <CtaBanner lang={lang} />
  </main>

  <Footer lang={lang} />
</BaseLayout>

{isMember && (
  <script define:vars={{ projectId: project.id }}>
    // Add milestone
    const addTrigger = document.querySelector("[data-add-milestone-trigger]");
    const formContainer = document.querySelector("[data-milestone-form-container]");
    const cancelBtn = formContainer?.querySelector("[data-cancel]");
    const form = formContainer?.querySelector("form");

    addTrigger?.addEventListener("click", () => {
      formContainer?.classList.remove("hidden");
      addTrigger.classList.add("hidden");
      const firstInput = form?.querySelector("input[name='title']");
      firstInput?.focus();
    });

    cancelBtn?.addEventListener("click", () => {
      formContainer?.classList.add("hidden");
      addTrigger?.classList.remove("hidden");
      form?.reset();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch(`/api/projects/${projectId}/milestones`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json().catch(() => ({}));
          alert(err.error || "Error creating milestone");
        }
      } catch {
        alert("Network error");
      }
    });

    // Delete milestone (delegated from timeline edit/delete icons)
    document.addEventListener("click", async (e) => {
      const deleteBtn = e.target?.closest("[data-delete-milestone]");
      if (!deleteBtn) return;

      const milestoneId = deleteBtn.dataset.deleteMilestone;
      if (!confirm("Are you sure?")) return;

      try {
        const res = await fetch(`/api/milestones/${milestoneId}`, { method: "DELETE" });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json().catch(() => ({}));
          alert(err.error || "Error deleting milestone");
        }
      } catch {
        alert("Network error");
      }
    });

    // Edit milestone placeholder (will be fully wired in Task 13)
    document.addEventListener("click", (e) => {
      const editBtn = e.target?.closest("[data-edit-milestone]");
      if (!editBtn) return;
      // TODO: wire edit form in Task 13
    });

    // Add project document
    document.querySelector("[data-add-project-doc]")?.addEventListener("click", async () => {
      const btn = document.querySelector("[data-add-project-doc]");
      const projId = btn?.dataset?.projectId;

      const title = prompt("Título del documento:");
      if (!title) return;

      const slug = title
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "");

      const docType = prompt("Tipo (prospect, lineament, bitacora, spec, custom):", "prospect");
      if (!docType) return;

      try {
        const res = await fetch("/api/documents", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, slug, doc_type: docType, scope: "project", project_id: Number(projId), content: "" }),
        });

        if (res.ok) {
          window.location.href = `/docs/${slug}?edit=true`;
        } else {
          const err = await res.json().catch(() => ({}));
          alert(err.error || "Error creating document");
        }
      } catch {
        alert("Network error");
      }
    });

    // Toggle task checkbox
    document.addEventListener("change", async (e) => {
      const checkbox = e.target?.closest("[data-task-checkbox]");
      if (!checkbox) return;

      const taskId = checkbox.dataset.taskCheckbox;
      const done = checkbox.checked;

      try {
        await fetch(`/api/tasks/${taskId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ done }),
        });
      } catch {
        // Revert on failure
        checkbox.checked = !done;
      }
    });

    // Run milestone trigger
    document.addEventListener("click", async (e) => {
      const btn = e.target?.closest("[data-run-milestone]");
      if (!btn || btn.disabled) return;

      const { projectId: pid, projectFolder, milestoneId, milestoneNumber, milestoneTitle } = btn.dataset;
      const msg = `¿Ejecutar milestone M${milestoneNumber} — ${milestoneTitle}?`;
      if (!confirm(msg)) return;

      btn.disabled = true;
      btn.textContent = "…";

      try {
        const res = await fetch("/api/run-milestone", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            project_id: Number(pid),
            milestone_id: Number(milestoneId),
            project_folder: projectFolder,
            milestone_number: Number(milestoneNumber),
          }),
        });

        if (res.ok) {
          const run = await res.json();
          // Start polling for status
          pollRunStatus(run.id);
          window.location.reload();
        } else {
          const err = await res.json().catch(() => ({}));
          alert(err.error || "Error triggering run");
          btn.disabled = false;
          btn.textContent = "Ejecutar";
        }
      } catch {
        alert("Network error");
        btn.disabled = false;
        btn.textContent = "Ejecutar";
      }
    });

    // Poll run status
    function pollRunStatus(runId) {
      const interval = setInterval(async () => {
        try {
          const res = await fetch(`/api/run-history/${runId}`);
          if (!res.ok) { clearInterval(interval); return; }
          const run = await res.json();
          if (run.status !== "queued" && run.status !== "running") {
            clearInterval(interval);
            window.location.reload();
          }
        } catch {
          clearInterval(interval);
        }
      }, 10000);
    }

    // Auto-poll any active runs on page load
    document.querySelectorAll("[data-run-row]").forEach((row) => {
      const statusEl = row.querySelector("[data-run-status]");
      if (statusEl) {
        const runId = statusEl.dataset.runStatus;
        const badge = statusEl.querySelector("span");
        const text = badge?.textContent?.trim().toLowerCase();
        if (text === "en cola" || text === "queued" || text === "ejecutando" || text === "running") {
          pollRunStatus(runId);
        }
      }
    });
  </script>
)}
