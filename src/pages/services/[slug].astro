---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import CtaBanner from "@/components/CtaBanner.astro";

export async function getStaticPaths() {
  const services = await getCollection("services");
  const portfolio = await getCollection("portfolio");

  return services.map((service) => {
    const relatedProjects = portfolio.filter((p) =>
      p.data.techStack.some((tech) =>
        service.data.title.toLowerCase().includes(tech.toLowerCase()) ||
        tech.toLowerCase().includes(service.data.slug.split("-")[0])
      )
    );

    return {
      params: { slug: service.data.slug },
      props: { service, relatedProjects },
    };
  });
}

const { service, relatedProjects } = Astro.props;
const { Content } = await render(service);
---

<BaseLayout
  title={`${service.data.title} — TopNotch`}
  description={service.data.summary}
  url={`/services/${service.data.slug}`}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Services", url: "/services" }, { name: service.data.title, url: `/services/${service.data.slug}` }]}
>
  <Navbar />

  <main>
    {/* Hero */}
    <section class="pt-24 pb-16 sm:pt-32 sm:pb-20 bg-neutral-50">
      <Container>
        <div class="max-w-3xl">
          <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 text-primary-600">
            <Fragment set:html={service.data.icon} />
          </div>
          <h1 class="font-heading text-4xl sm:text-5xl font-bold text-neutral-900 mb-4">
            {service.data.title}
          </h1>
          <p class="text-xl text-neutral-600 leading-relaxed">
            {service.data.summary}
          </p>
        </div>
      </Container>
    </section>

    {/* Content */}
    <section class="py-16 sm:py-20">
      <Container>
        <div class="max-w-3xl prose prose-neutral prose-lg prose-headings:font-heading prose-headings:text-neutral-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
          <Content />
        </div>
      </Container>
    </section>

    {/* Related portfolio items */}
    {relatedProjects.length > 0 && (
      <section class="py-16 sm:py-20 bg-neutral-50">
        <Container>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-neutral-900 mb-8">
            Related projects
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedProjects.map((project) => (
              <a
                href={`/portfolio/${project.data.slug}`}
                class="group block rounded-xl border border-neutral-200 bg-white overflow-hidden shadow-sm transition-all duration-base hover:shadow-lg hover:-translate-y-1"
              >
                <div class={`h-40 bg-gradient-to-br ${project.data.color ?? "from-primary-100 to-primary-200"} flex items-center justify-center`}>
                  <span class="font-heading text-lg font-semibold text-neutral-700/50">Screenshot</span>
                </div>
                <div class="p-5">
                  <h3 class="font-heading text-lg font-semibold text-neutral-900 mb-1">
                    {project.data.title}
                  </h3>
                  <p class="text-sm text-neutral-600 mb-3">{project.data.summary}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {project.data.techStack.slice(0, 4).map((tech) => (
                      <Badge variant="primary">{tech}</Badge>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    <CtaBanner />
  </main>

  <Footer />
</BaseLayout>
